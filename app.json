{
  "expo": {
    "name": "MK Widget Card",
    "slug": "MK_Widget_Card",
    "scheme": "mkwidgetcard",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mktech.widgetcard",
      "infoPlist": {
        "NSCameraUsageDescription": "Cho phép MK Widget Card truy cập camera để quét mã QR danh thiếp.",
        "NSPhotoLibraryUsageDescription": "Cho phép MK Widget Card chọn ảnh để đọc eCard hoặc cập nhật ảnh đại diện.",
        "NSContactsUsageDescription": "Cho phép MK Widget Card lưu eCard đã quét vào danh bạ của bạn."
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép MK Widget Card truy cập camera để quét mã QR danh thiếp.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "android": {
      "package": "com.mktech.widgetcard",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "fb9ff7c0-83bf-4f70-9970-5ef3bdff5300"
      }
    },
    "owner": "mktechvn",
    "runtimeVersion": "2.0.0",
    "updates": {
      "url": "https://u.expo.dev/fb9ff7c0-83bf-4f70-9970-5ef3bdff5300"
    }
  }
}
